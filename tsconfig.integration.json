{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "outDir": "./out/tests/integration",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "types": ["mocha", "node"]
  },
  "include": [
    "tests/integration/**/*.ts"
  ],
  "exclude": [
    "tests/integration/fixtures.ts",
    "tests/integration/extension.test.ts"
  ]
}
